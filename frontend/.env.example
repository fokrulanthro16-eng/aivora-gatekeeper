# ─────────────────────────────────────────────────────────────────────────────
# Aivora Gatekeeper — frontend environment variables
# Copy to .env and set values before running `npm run dev` or `npm run build`.
# All VITE_* variables are inlined at build time and visible in the browser bundle.
# Never put secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the FastAPI gatekeeper backend.
# Default: http://localhost:8000 (local dev)
VITE_API_BASE_URL=http://localhost:8000

# Set to "true" ONLY for local demos without a running backend or Supabase.
# When true:
#   • Button clicks activate the shield locally if the backend is offline.
#   • Metric cards show fake hardcoded numbers with a slow counter drift.
#   • The header shows a "Demo mode" badge.
# Default: false (production — backend is required for all status changes).
VITE_DEMO_MODE=false
