# ─────────────────────────────────────────────────────────────────────────────
# Aivora Gatekeeper — environment variable reference
# Copy to .env and fill in real values before starting any service.
# Lines starting with # are comments and are never read by the application.
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

# Runtime environment.  One of: development | staging | production
# Controls log format (human-readable vs JSON) and debug behaviour.
ENV=development

# Demo mode — set true ONLY for local development without a Supabase instance.
# When false (default/production):
#   • Missing SUPABASE_SERVICE_ROLE_KEY causes requests to be rejected.
#   • GATEWAY_FAIL_OPEN defaults to false (fail-closed).
#   • /health returns "degraded" if Supabase is not connected.
# When true:
#   • Missing credentials degrade gracefully (fail-open).
#   • Useful for UI demos and frontend development without a live database.
DEMO_MODE=false

# Set true only in local development.  Never true in production.
DEBUG=false

# Python log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO


# ── Supabase (required for production) ───────────────────────────────────────

# Full URL of your Supabase project.
# Local dev default: http://127.0.0.1:54321
# Cloud: https://<project-ref>.supabase.co
SUPABASE_URL=http://127.0.0.1:54321

# Service role key — has full database access, bypasses RLS.
# Found in: Supabase Dashboard → Project Settings → API → service_role key
# KEEP THIS SECRET.  Never commit the real value.  Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Timeout in seconds for Supabase RPC calls.
SUPABASE_RPC_TIMEOUT_SECONDS=5.0

# ── OpenRouter (required for /v1/aggregator/proxy-openrouter) ─────────────────

# Your OpenRouter API key.  Obtain from https://openrouter.ai/keys
# KEEP THIS SECRET — it has your billing attached.
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ── Polar.sh (required for /v1/webhooks/polar) ────────────────────────────────

# Webhook signing secret — found in Polar Dashboard → Webhooks → your endpoint.
# Used to verify that incoming events genuinely come from Polar.
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret-here

# Service token for outbound Polar API calls (subscription lookup, customer sync).
# Found in Polar Dashboard → Settings → API Tokens.
POLAR_ACCESS_TOKEN=your-polar-access-token-here


# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed browser origins, or * to allow all.
# In production, replace * with your actual frontend domain(s).
# Example: https://app.example.com,https://staging.example.com
CORS_ORIGINS=*

# Canonical public origin of the frontend (used to set CORS and CSP headers
# in production nginx / CDN config — not read directly by the FastAPI app).
FRONTEND_ORIGIN=http://localhost:5173


# ── LLM Providers ─────────────────────────────────────────────────────────────

# OpenRouter aggregation key — routes to GPT-4o, Claude, Gemini, and others
# from a single endpoint.  See https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Google Gemini direct API key (used if OpenRouter is unavailable).
# See https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Base URL of a local / self-hosted LLM (e.g. Ollama, LM Studio, vLLM).
# The circuit breaker falls back to this URL when all upstream providers fail.
# Must expose an OpenAI-compatible /v1/chat/completions endpoint.
LOCAL_LLM_FALLBACK_URL=http://localhost:11434/v1


# ── In-memory quota cache ──────────────────────────────────────────────────────

# TTL (seconds) for cached positive (allowed) quota decisions.
# Short to keep over-spend window small.
CACHE_DEFAULT_TTL_SECONDS=5

# TTL (seconds) for cached negative (blocked) quota decisions.
# Longer to reduce Supabase calls for users who are already rate-limited.
CACHE_NEGATIVE_TTL_SECONDS=15

# Maximum number of entries in the in-memory cache before LRU eviction.
CACHE_MAX_ENTRIES=10000


# ── Circuit breaker ────────────────────────────────────────────────────────────

# Number of consecutive failures before the circuit opens (blocks all calls).
CB_FAILURE_THRESHOLD=5

# Seconds to wait in OPEN state before allowing a single probe request
# (HALF_OPEN state).
CB_RECOVERY_TIMEOUT_SECONDS=60.0

# Number of consecutive successes in HALF_OPEN needed to fully close the circuit.
CB_HALF_OPEN_MAX_ATTEMPTS=2


# ── Token estimation ───────────────────────────────────────────────────────────

# Average characters per token used to estimate request cost from body text.
# 4.0 is a reasonable approximation for English prose.
TOKEN_CHARS_PER_TOKEN=4.0

# Default token cost for requests whose body cannot be parsed.
TOKEN_DEFAULT_COST=10

# Hard ceiling on any single request's estimated cost.
TOKEN_MAX_COST=10000


# ── Gateway behaviour ──────────────────────────────────────────────────────────

# When true, requests are allowed through if Supabase is unreachable (fail-open).
# Default is false (fail-closed / production safe).
# Set true only with DEMO_MODE=true or if you explicitly accept the risk.
GATEWAY_FAIL_OPEN=false
